# spec-template worker environment variables
# Copy this file to .env and fill in your values.
# .env is git-ignored — never commit actual secrets.

# ── Required ──────────────────────────────────────────────────────────────────

# GitHub Personal Access Token with repo read/write + issues + PRs
# Classic PAT: repo scope
# Fine-grained PAT: contents:write, issues:write, pull_requests:write
GITHUB_TOKEN=ghp_your_token_here

# Target repository in owner/repo format
TARGET_REPO=your-org/your-repo

# ── Auth: choose one ──────────────────────────────────────────────────────────

# Option A — Anthropic API key (pay-per-token; recommended for CI/CD)
# Get one at: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Option B — Claude Code subscription (use existing claude login credentials)
# Leave ANTHROPIC_API_KEY unset, and make sure ~/.claude/.credentials.json exists.
# run-worker.sh detects this automatically and mounts ~/.claude into the container.
# Note: only works when credentials are file-based (Linux). macOS/Windows store
# credentials in the OS keychain — use API key mode instead.

# ── Optional ──────────────────────────────────────────────────────────────────

# Branch to clone and work against (default: main)
# TARGET_BRANCH=main

# Claude model to use (default: Claude CLI's built-in default)
# Examples: claude-sonnet-4-6, claude-haiku-4-5, claude-opus-4-6
# MODEL=claude-sonnet-4-6

# Custom API endpoint for enterprise proxy / gateway deployments
# ANTHROPIC_BASE_URL=https://your-proxy.example.com

# Path to config directory inside the target repo (default: .claude)
# CLAUDE_CONFIG_PATH=.claude
