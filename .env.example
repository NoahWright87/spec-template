# ────────────────────────────────────────────────────────────────────────────────
# spec-template Worker — Environment Variables Example
# ────────────────────────────────────────────────────────────────────────────────
#
# Copy this file to .env and fill in your values. Never commit .env to git.
#
# See worker/README.md for full documentation on authentication modes and
# deployment options.

# ── Authentication ───────────────────────────────────────────────────────────────
# Choose ONE authentication mode:

# Option A: Claude Code subscription (personal use, mount ~/.claude directory)
#   No environment variables needed — just mount ~/.claude:/home/worker/.claude:ro

# Option B: Standard Anthropic API
# ANTHROPIC_API_KEY=sk-ant-...

# Optional: Custom API endpoint (for enterprise proxies or gateways)
# ANTHROPIC_BASE_URL=https://your-proxy.example.com

# ── GitHub Configuration ─────────────────────────────────────────────────────────
# Required: GitHub personal access token (repo read/write + issues + PRs)
GH_TOKEN=ghp_...

# Required: Target repository in owner/repo format
TARGET_REPO=your-org/your-repo

# Optional: Target branch (default: main)
TARGET_BRANCH=main

# ── Optional Parameters ──────────────────────────────────────────────────────────
# Path to .claude config directory in target repo (relative to repo root)
# CLAUDE_CONFIG_PATH=.claude

# Claude model to use (optional)
# If not specified, Claude CLI will use its default model
# Examples: claude-opus-4-6, claude-sonnet-4-5, claude-haiku-4-5
# Useful for: using Haiku for small tasks, Opus for complex ones, or specifying
# models available through a custom API endpoint
# MODEL=claude-sonnet-4-5
